  </div>

  <h2>Dining</h2>

  <div class="table-wrap">
    <table class="kv">
      <tbody>
        <tr><td>Daily table</td><td>Lift-top coffee table in living — converts from coffee height (~18") to dining height (~30"). Couch as bench.</td></tr>
        <tr><td>Guests (4–6)</td><td>Folding gate-leg timber table, stored under stairs. Pull out for gatherings.</td></tr>
      </tbody>
    </table>
  </div>

  <h2>Water Filtration</h2>
  <p>Multi-stage potable filter, 5 stages — see <a href={`${base}rainwater/`}>Rainwater Catchment</a> for full details.</p>

  <div class="page-nav">
    <a href={`${base}loft/`}>&larr; Bedroom Loft</a>
    <a href={`${base}envelope/`} class="next">Envelope &rarr;</a>
  </div>
</Layout>
