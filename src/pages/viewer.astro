  <h1>3D Model — 28' &times; 8'6"</h1>
  <p class="lead">Original plan. <a href="https://www.ironeagletinyhousetrailers-mobile.com/pricing-dimensions" target="_blank" rel="noopener">PAD-20k28</a>, triple 7k axles, 100" frame. <a href={`${base}viewer-26x10/`}>Compare with 26' &times; 10' variant &rarr;</a></p>

  <ViewerPage configName="28x8.5" />

  <div class="page-nav">
    <a href={`${base}open-questions/`}>&larr; Open Questions</a>
    <a href={`${base}viewer-26x10/`} class="next">26' &times; 10' Viewer &rarr;</a>
  </div>
</Layout>

<script>
  import '../lib/viewer-init';
</script>
